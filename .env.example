# =============================================================================
# Linkly URL Management Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment: development | production | test
NODE_ENV=development

# Backend server port
PORT=5000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Full connection URL (used by backend application)
DATABASE_URL=postgresql://linkly:linkly_secret@localhost:5432/linkly_db

# Individual credentials (used by Docker Compose for PostgreSQL container)
POSTGRES_USER=linkly
POSTGRES_PASSWORD=linkly_secret
POSTGRES_DB=linkly_db

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis password (used in production)
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens (CHANGE IN PRODUCTION - use a 64+ char random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Access token expiry (e.g., 15m, 1h, 1d)
JWT_ACCESS_EXPIRY=15m

# Refresh token expiry (e.g., 7d, 30d)
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Allowed origin for CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
# Base URL of the application (used for generating short URLs)
APP_URL=http://localhost

# Frontend URL (used for email links, redirects)
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username
SMTP_USER=your-email@gmail.com

# SMTP authentication password or app password
SMTP_PASS=your-email-password

# Sender email address
SMTP_FROM=noreply@linkly.dev

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Rate limit window in minutes
RATE_LIMIT_WINDOW=15

# Maximum requests per window
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# API base URL for the frontend (must be prefixed with VITE_)
VITE_API_URL=http://localhost:5000/api/v1

# -----------------------------------------------------------------------------
# Docker / Deployment
# -----------------------------------------------------------------------------
# GitHub repository (used for container registry)
GITHUB_REPOSITORY=your-username/scalable-url-shortener

# Docker image tag
IMAGE_TAG=latest
